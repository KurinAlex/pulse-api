{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run main.py with uv",
            "type": "shell",
            "command": "uv",
            "args": [
                "run",
                "src/main.py",
            ],
            "group": {
                "kind": "none",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Build docker image",
            "type": "shell",
            "command": "docker",
            "args": [
                "build",
                "-f",
                "docker/Dockerfile",
                "-t",
                "ytmusic-pulse:latest",
                "${workspaceFolder}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Run docker image",
            "type": "shell",
            "command": "docker",
            "args": [
                "run",
                "--env-file",
                ".env",
                "-p",
                "8000:8000",
                "ytmusic-pulse:latest",
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}